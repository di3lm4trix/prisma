// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id Int @id @default(autoincrement())
  name String @unique
  price Int @default(0)
  createdAt DateTime @default(now())
  // le decimos desde que modelo traer, como tipo de dato, le damos un atributo relacion, que requiere la columna de la tabla local, y de referencia la columna de la tabla importada
  category Category @relation(fields: [categoryID], references: [id])
  categoryID Int 
  stock Int @default(0)
}
// se relaciona
model Category{
  id Int @id @default(autoincrement())
  name String @unique
  products Product[]
}